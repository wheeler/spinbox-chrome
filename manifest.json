{
  "manifest_version": 3,
  "name": "Spinbox",
  "version": "0.0.1",
  "description": "Feed tools for SoundCloud that help you sort through new music more efficiently.",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["images/icon-16.png"],
      "matches": ["https://soundcloud.com/*"]
    }
  ],
  "content_scripts": [
    {
      "js": ["feed-page/content.js"],
      "css": ["feed-page/feed-page.css"],
      "run_at": "document_end",
      "matches": ["https://soundcloud.com/*"],
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": ["storage"]
}
