{
  "manifest_version": 3,
  "name": "Spinbox",
  "version": "0.0.1",
  "description": "A SoundCloud feed filter to help you dig in to new music with less repetition.",

  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "content_scripts": [
    {
      "js": ["feed-page/inject.js"],
      "matches": ["https://soundcloud.com/*"],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "js": [
        "feed-page/soundcloud-api.js",
        "feed-page/element-queries.js",
        "feed-page/content.js"
      ],
      "css": ["feed-page/feed-page.css"],
      "run_at": "document_end",
      "matches": [
        "https://soundcloud.com/*",
        "https://soundcloud.com/NOTE-because-soundcloud-is-a-SPA-we-need-to-match-all-pages-to-allow-for-navigation"
      ],
      "world": "ISOLATED"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": ["storage"]
}
